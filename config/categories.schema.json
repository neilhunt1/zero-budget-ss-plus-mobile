{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Budget Categories",
  "type": "object",
  "required": ["version", "groups"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": {
      "type": "integer",
      "description": "Schema version — increment when structure changes"
    },
    "groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "sort_order": { "type": "integer" },
          "subgroups": {
            "type": "array",
            "description": "Mid-level grouping — stored in sheet, ignored by app UI in v1",
            "items": {
              "type": "object",
              "required": ["name", "categories"],
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string" },
                "sort_order": { "type": "integer" },
                "categories": { "$ref": "#/definitions/categoryList" }
              }
            }
          },
          "categories": {
            "$ref": "#/definitions/categoryList",
            "description": "Direct categories if no subgroups — one or the other, not both"
          }
        },
        "oneOf": [
          {
            "required": ["categories"],
            "not": { "required": ["subgroups"] }
          },
          {
            "required": ["subgroups"],
            "not": { "required": ["categories"] }
          }
        ]
      }
    }
  },
  "definitions": {
    "categoryList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "Display name including emoji if desired"
          },
          "type": {
            "type": "string",
            "enum": ["fluid", "fixed_bill", "savings_target", "targeted_amount"],
            "description": "fluid=freely moveable monthly spending | fixed_bill=committed bill/obligation (any frequency/amount) | savings_target=accruing envelope for irregular spend | targeted_amount=like savings_target but with an explicit goal amount/timeline (phase 1: behaves identically to savings_target)"
          },
          "template": {
            "type": "number",
            "minimum": 0,
            "description": "Default monthly assignment amount — applied when Apply Template is tapped"
          },
          "sort_order": { "type": "integer" },
          "active": {
            "type": "boolean",
            "default": true,
            "description": "Inactive categories hidden from picker and Plan screen but retained in history"
          }
        }
      }
    }
  }
}
