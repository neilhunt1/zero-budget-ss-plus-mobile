# E2E test environment — copy to .env.test and fill in values
# .env.test is gitignored; this file is committed as documentation

# The BTSZB-Test Google Sheet ID (separate from dev and prod)
GOOGLE_SHEET_ID_TEST=your_test_sheet_id_here

# Used by Vite build when running E2E tests locally
VITE_GOOGLE_SHEET_ID=your_test_sheet_id_here

# Service account credentials — two options, use whichever fits your setup:

# Option A: inline JSON (used in CI via GitHub Secret)
# E2E_SERVICE_ACCOUNT_TOKEN={"type":"service_account","project_id":"...","private_key":"..."}

# Option B: path to JSON key file (easier for local development)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/path/to/your-service-account-key.json
