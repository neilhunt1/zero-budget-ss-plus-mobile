# Copy to .env.development or .env.production and fill in values.
# Never commit .env.development or .env.production — they contain secrets.

# The ID of the Google Sheet (from the URL: /spreadsheets/d/<SHEET_ID>/edit)
GOOGLE_SHEET_ID=your_sheet_id_here

# ── Service account credentials (choose one) ──────────────────────────────────

# Option A — Inline JSON key contents (recommended for cloud/CI environments).
# Paste the entire contents of your service account JSON key as a single line.
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# Option B — Path to a local JSON key file (recommended for local development).
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account-key.json
