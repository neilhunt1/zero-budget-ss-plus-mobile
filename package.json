{
  "name": "zero-budget",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "setup:dev": "ts-node --project tsconfig.scripts.json scripts/setup-sheet.ts --env dev",
    "setup:prod": "ts-node --project tsconfig.scripts.json scripts/setup-sheet.ts --env prod",
    "import:ynab:plan:dev": "ts-node --project tsconfig.scripts.json scripts/sync-from-ynab.ts --env dev",
    "import:ynab:plan:prod": "ts-node --project tsconfig.scripts.json scripts/sync-from-ynab.ts --env prod",
    "sync-from-prod-to-dev": "ts-node --project tsconfig.scripts.json scripts/sync-from-prod-to-dev.ts",
    "import:ynab:register:dev": "ts-node --project tsconfig.scripts.json scripts/import-ynab-transactions.ts --env dev",
    "import:ynab:register:prod": "ts-node --project tsconfig.scripts.json scripts/import-ynab-transactions.ts --env prod",
    "test:integration": "vitest run tests/integration --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:mobile": "playwright test --project=mobile-safari --project=mobile-chrome",
    "test:e2e:desktop": "playwright test --project=desktop-chrome --project=desktop-webkit",
    "setup:test": "ts-node --project tsconfig.scripts.json scripts/setup-sheet.ts --env test",
    "seed:test": "ts-node --project tsconfig.scripts.json scripts/seed-test-sheet.ts"
  },
  "dependencies": {
    "@react-oauth/google": "^0.12.1",
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^4.4.0",
    "dotenv": "^16.4.5",
    "googleapis": "^173.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.0",
    "sharp": "^0.34.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8",
    "workbox-precaching": "^7.4.1"
  }
}
